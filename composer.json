{
    "name": "foodieneers/laravel-tag",
    "description": "Laravel Package for Tagging Users",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "Foodieneers",
        "laravel",
        "laravel-tag"
    ],
    "homepage": "https://github.com/foodieneers/laravel-tag",
    "authors": [
        {
            "name": "Azzarip",
            "email": "paride21azzari@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "foodieneers/laravel-devtools": "dev-main",
        "matthewbdaly/artisan-standalone": "*",
        "nunomaduro/mock-final-classes": "^1.2",
        "orchestra/testbench": "*"
    },
    "autoload": {
        "psr-4": {
            "Foodieneers\\Tag\\": "src/",
            "Foodieneers\\Tag\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Foodieneers\\Tag\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {

    "dep:bump": "composer bump",
    "lint": [
        "rector",
        "pint --parallel"
    ],
    "test:type-coverage": "pest --type-coverage --min=100",
    "test:lint": [
        "pint --parallel --test",
        "rector --dry-run"
    ],
    "pest": "pest",
    "test:unit": "pest --parallel --coverage --exactly=100.0",
    "test:types": "phpstan",
     "test": [
        "@test:type-coverage",
        "@test:unit",
        "@test:lint",
        "@test:types"
    ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Foodieneers\\Tag\\TagServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
